# Database
# For Supabase: copy the "Connection string" → Transaction pooler from Project Settings → Database.
# It looks like: postgresql://postgres.[ref]:[pw]@[host]:6543/postgres
# The backend auto-converts to asyncpg + adds ssl=require for Supabase domains.
DATABASE_URL=postgresql+asyncpg://csrankings:csrankings@db:5432/csrankings
DATABASE_URL_SYNC=postgresql://csrankings:csrankings@db:5432/csrankings

# Supabase Auth — paste from Supabase project Settings → API
SUPABASE_URL=
SUPABASE_JWT_SECRET=

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=CS Rankings
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Elasticsearch (optional)
ELASTICSEARCH_URL=http://elasticsearch:9200

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# Observability — backend (Sentry)
# Get DSN from https://sentry.io/ → Projects → your project → Settings → Client Keys (DSN)
SENTRY_DSN=
SENTRY_ENV=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# Observability — frontend (these belong in frontend env, .env.local in Next.js,
# or as Cloudflare Pages env vars. Listed here for reference.)
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN — get from Cloudflare dashboard → Web Analytics → your site
# NEXT_PUBLIC_SENTRY_DSN — same project as backend, or a separate frontend project
# NEXT_PUBLIC_SENTRY_ENV=production
# NEXT_PUBLIC_API_URL=https://YOUR-APP.fly.dev/api/v1
# NEXT_PUBLIC_API_BASE=https://YOUR-APP.fly.dev

# Frontend Supabase (Cloudflare Pages env vars) — both required for OAuth/magic-link sign-in
# NEXT_PUBLIC_SUPABASE_URL=https://[ref].supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...  (from Supabase Settings → API → Project API keys → anon public)
