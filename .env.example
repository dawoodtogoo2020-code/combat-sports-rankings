# Database
DATABASE_URL=postgresql+asyncpg://csrankings:csrankings@db:5432/csrankings
DATABASE_URL_SYNC=postgresql://csrankings:csrankings@db:5432/csrankings

# Redis
REDIS_URL=redis://redis:6379/0

# JWT
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# App
APP_NAME=CS Rankings
APP_ENV=development
APP_DEBUG=true
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Elasticsearch (optional)
ELASTICSEARCH_URL=http://elasticsearch:9200

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
