# App
APP_ENV=production
APP_DEBUG=false
PORT=8000

# Database (Railway injects these automatically with PostgreSQL plugin)
DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:pass@host:5432/dbname

# Redis (Railway injects with Redis plugin)
REDIS_URL=redis://host:6379/0

# JWT — MUST generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-to-a-random-secret-in-production

# CORS — your frontend domain
CORS_ORIGINS=["https://combat-sports-rankings.pages.dev"]
FRONTEND_URL=https://combat-sports-rankings.pages.dev

# First deploy only — set to true to seed the database, then remove
# RUN_SEED=true
